* text=auto

# Ensure consistent line endings
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.sh text eol=lf
*.dockerignore text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
LICENSE text eol=lf
Dockerfile text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
*.sqlite binary
